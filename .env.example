# Supabase project credentials. Copy this file to .env.local and fill in
# the values from Supabase dashboard -> Settings -> API.
#
# - VITE_SUPABASE_URL is the "Project URL"
# - VITE_SUPABASE_ANON_KEY is the "anon public" key (NOT the service_role key)
#
# The OS connects to the same Supabase project that powers join-orion.com
# (see memory/project_shared_supabase_with_join_orion.md for details).

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
